func write(buf table, data table) {
    foreach i, v = data {
        buf[i] = v
    }
}

func findElement(table table, elem any) {
    foreach k, v = table {
        if v == elem {
            return k
        }
    }
    return void
}

func concat(a table, b table) {
    foreach k,v = b {
        a[k] = v
    }
    
    return a
}

func append(table table, elem any) {
    table[len(table)] = elem
}
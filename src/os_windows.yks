@external "kernel32.dll"

import "sys"
import "tables"

yar kernelReadFile pointer, kernelWriteFile pointer, kernelCreateFileW pointer, kernelCloseHandle pointer = kernel32("ReadFile"), kernel32("WriteFile"), kernel32("CreateFileW"), kernel32("CloseHandle")

struct File {
    h,
    func read(buf) {
        if buf == void {
            buf = make(1024, 0, 8)
        }

        yar _, _, err = kernelReadFile(
            this->h,
            buf,
            len(buf),
            void,
            void
        )

        return buf, err
    }
     func write(buf) {
        if buf == void {
            throw("Write buffer cannot be a 'void' value")
        }

        yar _, _, err = kernelWriteFile(
            this->h,
            buf,
            len(buf),
            void,
            void
        )

        return err
    }
    func close() {
        yar _, _, err = kernelCloseHandle(this->h)

        return err
    }
}

func createFile(name) {
    yar r1, _, err = kernelCreateFileW(name,
        GENERIC_READ|GENERIC_WRITE, FILE_SHARE_READ|FILE_SHARE_WRITE,
		void,
		CREATE_ALWAYS,
		FILE_ATTRIBUTE_NORMAL,
		0)

    return new File{
        h: r1,
    }, err
}

func openFile(name) {
    yar r1, _, err = kernelCreateFileW(name,
        GENERIC_READ|GENERIC_WRITE, FILE_SHARE_READ|FILE_SHARE_WRITE,
		void,
		OPEN_EXISTING,
		FILE_ATTRIBUTE_NORMAL,
		0)

    return new File{
        h: r1,
    }, err
}